\newlabel{sec:l2barrier}{{5.5}{6}{The L2 Cache Barrier: Why Roofline Fails for Small-Matrix MLA Reconstruction}{subsection.48}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces The L2 cache barrier. Roofline analysis predicts 2--3.9$\times $ INT4 speedup assuming HBM-bound operation. Measured performance shows 0.2--0.5$\times $: the INT4 kernel is \emph  {slower} than cuBLAS FP16. The 16\,MB reconstruction weight fits in H100's 50\,MB L2; after first access, weights are served from L2 at ${\sim }$12\,TB/s, making HBM savings irrelevant.}}{6}{figure.caption.47}\protected@file@percent }
\newlabel{fig:l2barrier}{{6}{6}{The L2 cache barrier. Roofline analysis predicts 2--3.9$\times $ INT4 speedup assuming HBM-bound operation. Measured performance shows 0.2--0.5$\times $: the INT4 kernel is \emph {slower} than cuBLAS FP16. The 16\,MB reconstruction weight fits in H100's 50\,MB L2; after first access, weights are served from L2 at ${\sim }$12\,TB/s, making HBM savings irrelevant}{figure.caption.47}{}}
